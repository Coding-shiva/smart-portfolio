PORT=5000
NODE_ENV=development

# Database Connection (MongoDB Atlas URI)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/portfolio?retryWrites=true&w=majority

# JWT Token Secret Key
JWT_SECRET=yoursecretkey12345

# Allowed Client Origin URL (React Frontend Server)
CLIENT_URL=http://localhost:5173

# Google Gemini API Key (Required for resume analyzer, career advisor, chatbot, interview assistant)
# Obtain it from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# SMTP Server Configurations (Nodemailer Contact Form Alerts)
# Leave blank to fall back to terminal logging outbox
SMTP_HOST=
SMTP_PORT=587
EMAIL_USER=
EMAIL_PASS=
NOTIFICATION_EMAIL=
